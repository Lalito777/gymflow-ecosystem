# GymFlow - variables de entorno de referencia
#
# Este archivo es SOLO documentacion. No lo usa docker-compose ni Render directamente:
# - En local (docker-compose.yml), las variables ya estan escritas directo en el archivo.
# - En Render, render.yaml genera estas mismas variables automaticamente (fromService/fromDatabase)
#   y las de tipo "sync: false" te las pide el dashboard la primera vez que crees el Blueprint.
# Sirve para que entiendas que existe cada variable y la puedas explicar en la defensa.

# --- Comunes a los 12 servicios ---
SPRING_PROFILES_ACTIVE=render          # activa application-render.yml (Postgres real / URLs dinamicas)
PORT=8080                              # puerto que Render asigna; cada servicio lo usa via -Dserver.port
EUREKA_HOST=                           # host interno del eureka-server (lo llena Render con fromService)
EUREKA_PORT=                           # puerto interno del eureka-server (lo llena Render con fromService)

# --- Solo user-service ---
BRANCH_HOST=                           # host interno de branch-service (fromService)
BRANCH_PORT=                           # puerto interno de branch-service (fromService)

# --- Solo class-service ---
MEMBERSHIP_HOST=                       # host interno de membership-service (fromService)
MEMBERSHIP_PORT=                       # puerto interno de membership-service (fromService)

# --- Solo user-service, branch-service, membership-service, access-service (Postgres real) ---
DB_HOST=                               # host de la base gymflow-postgres (fromDatabase)
DB_PORT=                               # puerto de la base gymflow-postgres (fromDatabase)
DB_NAME=                               # nombre de la base (fromDatabase: property "database")
DB_USER=                               # usuario de Postgres (fromDatabase)
DB_PASSWORD=                           # password de Postgres (fromDatabase) - NUNCA la escribas aqui en texto plano
